{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@kinos/core": ["../../core/src/index.ts"],
      "@kinos/executor-local": ["../../adapters/executor-local/src/index.ts"],
      "@kinos/persistence-sqlite": ["../../adapters/persistence-sqlite/src/index.ts"],
      "@kinos/runtime-hermes": ["../../adapters/runtime-hermes/src/index.ts"],
      "@kinos/runtime-ollama": ["../../adapters/runtime-ollama/src/index.ts"],
      "@kinos/runtime-openai": ["../../adapters/runtime-openai/src/index.ts"]
    }
  },
  "references": [
    { "path": "../../core" },
    { "path": "../../adapters/executor-local" },
    { "path": "../../adapters/persistence-sqlite" },
    { "path": "../../adapters/runtime-hermes" },
    { "path": "../../adapters/runtime-ollama" },
    { "path": "../../adapters/runtime-openai" }
  ],
  "include": ["src/**/*.ts"],
  "exclude": ["**/*.test.ts", "dist"]
}
