# KinOS environment — copy to `.env` and fill in. `.env` is gitignored.
# Everything here is OPTIONAL: with none set, the stack runs fully in dev mode
# (FakeAuthBroker for OAuth, a local Hermes/Ollama model). Set a section only when
# you want that real integration.
#
# `docker compose` reads `.env` from the repo root automatically.

# ─────────────────────────────────────────────────────────────────────────────
# Real Google integrations (Calendar, Drive) — RFC-017/032/033
# ─────────────────────────────────────────────────────────────────────────────
# You need the KinOS app's OAuth CLIENT — an "OAuth 2.0 Client ID" of type
# "Web application" from Google Cloud Console (NOT a service-account key). One
# client covers every Google provider (calendar + drive); users never type a
# secret, they click "Connect". Unset → the deterministic FakeAuthBroker (dev).
#
# In Google Cloud Console (same project as the client):
#   • APIs & Services → Library → enable "Google Calendar API" and "Google Drive API"
#   • OAuth consent screen → add yourself (+ family) as Test users while in Testing
#   • Credentials → your OAuth client → set:
#       Authorized redirect URI:   http://localhost:8787/api/auth/callback/google
#       Authorized JavaScript origins: (not required — server-side auth-code flow)
#     In production, replace the host with your public API domain (https).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Any random string, >= 32 chars (signs Better Auth sessions). Generate e.g.:
#   openssl rand -base64 32
BETTER_AUTH_SECRET=

# The API as the BROWSER reaches it — Better Auth derives the Google redirect_uri
# from this, and Google redirects the browser there, so it must be browser-reachable.
# NOT the compose name http://api:8787 (that is KINOS_PUBLIC_URL, for Hermes only).
# The value to whitelist in Google is `${BETTER_AUTH_URL}/api/auth/callback/google`.
BETTER_AUTH_URL=http://localhost:8787
# Where Better Auth returns the browser after consent (KinOS stores the account
# reference here). Internal to KinOS — NOT a Google redirect URI.
KINOS_OAUTH_REDIRECT_URI=http://localhost:8787/oauth/connected

# ─────────────────────────────────────────────────────────────────────────────
# Harness (Hermes) / local model — overrides for docker-compose defaults
# ─────────────────────────────────────────────────────────────────────────────
# Shared between the api and hermes services (>= 16 chars). Default is a dev key.
# HERMES_API_KEY=kinos-harness-devkey-0001
# Hermes' own inference backend (its default profile model) and context window.
# HARNESS_MODEL=gemma4-128k
# HARNESS_OLLAMA_URL=http://host.docker.internal:11434/v1
# HARNESS_MODEL_CONTEXT=65536
# UID/GID Hermes runs as inside its container.
# HERMES_UID=10000
# HERMES_GID=10000

# ─────────────────────────────────────────────────────────────────────────────
# Console (UI)
# ─────────────────────────────────────────────────────────────────────────────
# Host port for the operator console (default 3100; 3000/3005 are often taken).
# KINOS_UI_PORT=3100
